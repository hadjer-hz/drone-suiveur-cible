<?xml version="1.0"?>
<sdf version="1.9">
  <model name="arm">
    <pose>0 0 0 0 0 0</pose>

    <!-- Base -->
    <link name="base">
      <pose>0 0 0.025 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia><ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="base_vis">
        <geometry><cylinder><radius>0.06</radius><length>0.05</length></cylinder></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <collision name="base_col">
        <geometry><cylinder><radius>0.06</radius><length>0.05</length></cylinder></geometry>
      </collision>
    </link>

    <!-- Link 1 -->
    <link name="link1">
      <pose>0 0 0.125 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.005</ixx><iyy>0.005</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="link1_vis">
        <geometry><box><size>0.04 0.04 0.15</size></box></geometry>
        <material><ambient>0.2 0.2 0.8 1</ambient><diffuse>0.2 0.2 0.8 1</diffuse></material>
      </visual>
      <collision name="link1_col">
        <geometry><box><size>0.04 0.04 0.15</size></box></geometry>
      </collision>
    </link>

    <joint name="joint1" type="revolute">
      <parent>base</parent>
      <child>link1</child>
      <pose>0 0 -0.075 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper><effort>10</effort><velocity>1</velocity></limit>
      </axis>
    </joint>

    <!-- Link 2 -->
    <link name="link2">
      <pose>0 0 0.30 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia><ixx>0.004</ixx><iyy>0.004</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="link2_vis">
        <geometry><box><size>0.03 0.03 0.20</size></box></geometry>
        <material><ambient>0.2 0.2 0.8 1</ambient><diffuse>0.2 0.2 0.8 1</diffuse></material>
      </visual>
      <collision name="link2_col">
        <geometry><box><size>0.03 0.03 0.20</size></box></geometry>
      </collision>
    </link>

    <joint name="joint2" type="revolute">
      <parent>link1</parent>
      <child>link2</child>
      <pose>0 0 -0.10 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper><effort>10</effort><velocity>1</velocity></limit>
      </axis>
    </joint>

    <!-- Link 3 -->
    <link name="link3">
      <pose>0 0 0.49 0 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia><ixx>0.003</ixx><iyy>0.003</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="link3_vis">
        <geometry><box><size>0.025 0.025 0.18</size></box></geometry>
        <material><ambient>0.2 0.2 0.8 1</ambient><diffuse>0.2 0.2 0.8 1</diffuse></material>
      </visual>
      <collision name="link3_col">
        <geometry><box><size>0.025 0.025 0.18</size></box></geometry>
      </collision>
    </link>

    <joint name="joint3" type="revolute">
      <parent>link2</parent>
      <child>link3</child>
      <pose>0 0 -0.09 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper><effort>10</effort><velocity>1</velocity></limit>
      </axis>
    </joint>

    <!-- Link 4 -->
    <link name="link4">
      <pose>0 0 0.63 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.002</ixx><iyy>0.002</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="link4_vis">
        <geometry><box><size>0.02 0.02 0.10</size></box></geometry>
        <material><ambient>0.8 0.2 0.2 1</ambient><diffuse>0.8 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name="link4_col">
        <geometry><box><size>0.02 0.02 0.10</size></box></geometry>
      </collision>
    </link>

    <joint name="joint4" type="revolute">
      <parent>link3</parent>
      <child>link4</child>
      <pose>0 0 -0.05 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1.57</lower><upper>1.57</upper><effort>10</effort><velocity>1</velocity></limit>
      </axis>
    </joint>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint1</joint_name>
      <topic>/arm/joint1</topic>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint2</joint_name>
      <topic>/arm/joint2</topic>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint3</joint_name>
      <topic>/arm/joint3</topic>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint4</joint_name>
      <topic>/arm/joint4</topic>
      <p_gain>10</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>

  </model>
</sdf>
